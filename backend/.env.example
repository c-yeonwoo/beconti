# ─── AI ───────────────────────────────────────────────────────────
# Google AI Studio 에서 발급: https://aistudio.google.com/apikey
# 비워두면 generate 는 스텁(더미) 초안을 반환 → 키 없이도 파이프라인 테스트 가능
GEMINI_API_KEY=
# 1.5-pro 는 deprecated. 2.5-flash(추천) / 2.5-pro / 2.0-flash 중 선택
GEMINI_MODEL=gemini-2.5-flash

# (Phase 2) Anthropic - 숏폼 대본 품질 업. 비우면 Gemini 결과 그대로 사용
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# ─── 숏폼 음성/음악 ───────────────────────────────────────────────
# Typecast TTS (내레이션 음성). 비우면 TTS 생략. 발급: https://typecast.ai
TYPECAST_API_KEY=
# 음성 ID (tc_...). GET /v2/voices 로 확인. 비우면 TTS 생략
TYPECAST_VOICE_ID=
TYPECAST_MODEL=ssfm-v30
# 나레이션 배속 (겹침/짤림 방지). 1.0=기본, 1.2=20% 빠르게(권장)
TTS_TEMPO=1.2
# 배경음악: data/bgm/ 폴더에 mp3/wav 파일을 넣으면 자동 사용 (저작권 안전한 음원)
BGM_VOLUME=0.15
NARRATION_VOLUME=1.0
ORIG_AUDIO_VOLUME=0.25

# ─── 저장소 ────────────────────────────────────────────────────────
DATA_DIR=./data

# ─── 네이버 배포 (Playwright) ──────────────────────────────────────
# 비워두면 자동화 전용 프로필(data/naver-profile)을 사용 → 메인 크롬과 독립.
# 최초 1회 `python naver_login.py` 로 네이버 로그인하면 세션이 저장됨.
# (메인 크롬 프로필을 직접 쓰려면 그 경로를 여기 지정 — 단 크롬을 닫아야 함)
NAVER_CHROME_USER_DATA_DIR=
# 블로그 아이디 (blog.naver.com/{이 값})
NAVER_BLOG_ID=
# true 면 실제 발행하지 않고 에디터까지만 진행 후 스크린샷 (안전 기본값)
PUBLISH_DRY_RUN=true
# Playwright 브라우저 표시 여부 (매크로는 headful 권장)
PLAYWRIGHT_HEADLESS=false

# ─── CORS ─────────────────────────────────────────────────────────
# 쉼표구분. 비우면 모든 localhost 포트 허용 (개발 편의)
CORS_ORIGINS=
